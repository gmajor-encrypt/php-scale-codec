{
    "name": "gmajor/substrate-codec-php",
    "description": "PHP SCALE Codec for Substrate - v2.0",
    "keywords": ["substrate", "polkadot", "scale", "codec", "blockchain"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "gmajor-encrypt"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^8.2",
        "ext-gmp": "*",
        "ext-json": "*",
        "ext-sodium": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7",
        "phpbench/phpbench": "^1.2"
    },
    "autoload": {
        "psr-4": {
            "Substrate\\ScaleCodec\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Substrate\\ScaleCodec\\Tests\\": "tests/",
            "Substrate\\ScaleCodec\\Benchmark\\": "benchmark/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse",
        "cs": "phpcs --standard=PSR12 src tests",
        "bench": "phpbench run --report=default",
        "bench:full": "phpbench run --profile=full --report=default",
        "bench:quick": "phpbench run --profile=quick --report=default"
    },
    "config": {
        "sort-packages": true
    }
}
